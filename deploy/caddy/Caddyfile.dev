# Dev Caddyfile — used with docker-compose.dev.yml.
# Supports running API/Web natively on the host (npm run dev) while Caddy runs
# in Docker, so upstreams resolve via host.docker.internal.
# sitey-api pushes a full config via POST :2019/load on startup, replacing this.
{
    admin 0.0.0.0:2019
}

:80 {
    @api path /trpc/* /webhook/* /health/*
    handle @api {
        reverse_proxy host.docker.internal:3001
    }
    handle {
        reverse_proxy host.docker.internal:3000
    }
}
