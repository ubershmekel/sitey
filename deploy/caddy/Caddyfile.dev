# Dev Caddyfile — used with docker-compose.dev.yml.
# Both sitey-api and sitey-web run as Docker services on the same network,
# so they resolve by service name (no host.docker.internal needed).
# sitey-api pushes a full config via POST :2019/load on startup, replacing this.
{
    admin 0.0.0.0:2019
}

:80 {
    @api path /trpc/* /webhook/* /health/*
    handle @api {
        reverse_proxy sitey-api:3001
    }
    handle {
        reverse_proxy sitey-web:3000
    }
}
