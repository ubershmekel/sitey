# ─── Required ────────────────────────────────────────────────────────────────

# The domain where Sitey itself is accessible (management UI + API)
SITEY_DOMAIN=sitey.yourdomain.com

# Email for Let's Encrypt certificate notifications (used by Caddy globally)
ACME_EMAIL=admin@yourdomain.com

# ─── Security ─────────────────────────────────────────────────────────────────

# JWT signing secret — generate with: openssl rand -hex 32
JWT_SECRET=change-me-to-a-random-32-byte-hex-string

# Admin email for the initial account
ADMIN_EMAIL=admin@sitey.local

# ─── Optional ─────────────────────────────────────────────────────────────────

# Log level: debug | info | warn | error (default: info)
LOG_LEVEL=info

# Where persistent data lives on the host (default: ./data)
# DATA_ROOT=/opt/sitey/data
