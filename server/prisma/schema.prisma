generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id                 String   @id @default(cuid())
  email              String   @unique
  passwordHash       String
  mustChangePassword Boolean  @default(true)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}

model Domain {
  id               String         @id @default(cuid())
  hostname         String         @unique
  letsEncryptEmail String
  status           String         @default("pending") // pending | active | error
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  routes           ProjectRoute[]
}

model Project {
  id            String         @id @default(cuid())
  name          String

  // GitHub source
  repoOwner     String         @default("")
  repoName      String         @default("")
  branch        String         @default("main")

  // Deploy mode
  deployMode    String         @default("server") // server | static
  buildCommand  String         @default("")       // static: e.g. "npm run build"
  outputDir     String         @default("dist")   // static: output directory

  // Build / run
  buildMode     String         @default("auto") // auto | dockerfile
  containerPort Int            @default(3000)
  hostPort      Int?           // auto-allocated fallback port when the project has no routes
  envVars       String         @default("{}") // JSON map

  // GitHub integration
  githubMode    String         @default("webhook") // webhook | app
  webhookSecret String?
  githubInstallationId String?

  // Runtime state
  status        String         @default("idle") // idle | building | running | failed | stopped
  containerId   String?
  containerName String?

  // System-managed projects (e.g. the sitey UI itself) cannot be deleted
  protected     Boolean        @default(false)

  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  routes        ProjectRoute[]
  deployments   Deployment[]
}

// A route is a (domain, pathPrefix) pair that points traffic to a project.
// Either field can be absent:
//   domain=null, pathPrefix=""      → catches everything (root) — reserved for sitey
//   domain=set,  pathPrefix=""      → example.com/ or app.example.com/
//   domain=null, pathPrefix="/blog" → <server-ip>/blog/
//   domain=set,  pathPrefix="/blog" → example.com/blog/
// Subdomains are just domains: add app.example.com as its own Domain record.
model ProjectRoute {
  id          String   @id @default(cuid())
  projectId   String
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  domainId    String?
  domain      Domain?  @relation(fields: [domainId], references: [id], onDelete: Cascade)

  pathPrefix  String   @default("") // e.g. "/blog" — empty means the root of this host

  // Protected routes cannot be deleted (used for the sitey root route)
  protected   Boolean  @default(false)

  createdAt   DateTime @default(now())

  @@unique([domainId, pathPrefix])
}

model Deployment {
  id            String    @id @default(cuid())
  projectId     String
  project       Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)

  status        String    @default("queued") // queued | building | running | success | failed
  commitSha     String?
  commitMessage String?
  logPath       String?
  triggeredBy   String    @default("manual") // manual | webhook

  startedAt     DateTime?
  finishedAt    DateTime?
  createdAt     DateTime  @default(now())
}

// Key-value store for system-wide settings
model SystemConfig {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}
