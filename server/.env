# This server/.env file is for dev
# It only affects local tsx (which auto-loads it).
# The production container gets its env vars from
# docker-compose.yml's environment block
DATABASE_URL="file:../../deploy/data/sitey.db"
JWT_SECRET="dev-insecure-change-me-in-production"
ADMIN_EMAIL="admin@sitey.local"
DATA_ROOT="./data"
PORT=3001
LOG_LEVEL=debug
SITEY_URL=http://localhost:3001
CORS_ORIGIN=http://localhost:3000
CADDY_ADMIN_URL=http://localhost:2019
SITEY_API_INTERNAL=host.docker.internal:3001
