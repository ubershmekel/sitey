# SSH target, for example:
# SSH_TARGET=root@12.34.56.78
SSH_TARGET=

# Public URL of your Sitey instance (optional, but recommended).
# Example: https://sitey.example.com
SITEY_URL=

# Remote deploy directory (optional).
# Default: /opt/sitey/deploy
REMOTE_DEPLOY_DIR=/opt/sitey/deploy

# How to get latest code before reset:
# pull      -> git pull --ff-only in remote repo (recommended)
# installer -> runs install-ubuntu.sh one-liner first
# none      -> skip code refresh
REFRESH_MODE=installer
